{
  "name": "document-analysis-app",
  "version": "0.1.0",
  "description": "Desktop app for document relationship analysis with AI",
  "main": "./dist/main/index.js",
  "scripts": {
    "format": "prettier --write \"src/**/*.{ts,tsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json,css,md}\"",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "lint:fix": "eslint \"src/**/*.{ts,tsx}\" --fix",
    "type-check": "tsc --noEmit -p tsconfig.main.json && tsc --noEmit -p tsconfig.renderer.json",
    "check": "npm run format:check && npm run lint && npm run type-check",
    "dev": "concurrently \"npm run dev:main\" \"npm run dev:renderer\"",
    "dev:main": "tsc -p tsconfig.main.json --watch",
    "dev:renderer": "vite",
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "start": "electron .",
    "rebuild": "electron-rebuild -f -w better-sqlite3 -w keytar",
    "postinstall": "npm run rebuild"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.1024.0",
    "@aws-sdk/client-s3": "^3.1024.0",
    "@aws-sdk/client-textract": "^3.1024.0",
    "@qdrant/js-client-rest": "^1.17.0",
    "amqplib": "^1.0.3",
    "better-sqlite3": "^12.8.0",
    "cytoscape": "^3.30.4",
    "electron": "^41.1.1",
    "keytar": "^7.9.0",
    "neo4j-driver": "^6.0.1",
    "react": "^19.2.4",
    "react-cytoscapejs": "^2.0.0",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@types/amqplib": "^0.10.8",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cytoscape": "^3.21.9",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "concurrently": "^9.2.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9.20.0",
    "eslint-config-prettier": "^10.1.0",
    "eslint-plugin-react": "^7.38.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "prettier": "^3.4.2",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.3"
  }
}
